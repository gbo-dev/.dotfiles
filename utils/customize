#!/usr/bin/env bash
set -euo pipefail

# Fuzzel customization menu
# References ~/.dotfiles directly for all operations

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOTFILES_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"

WAYBAR_TOGGLE="${DOTFILES_DIR}/utils/waybar-profile"
WAYBAR_THEMES_DIR="${DOTFILES_DIR}/waybar/.config/waybar/themes"
WALLPAPER_DIR="${DOTFILES_DIR}/hypr/.config/hypr/wallpapers"

FUZZEL_COMMON_OPTS=(
    --dmenu
    --config "${DOTFILES_DIR}/fuzzel/.config/fuzzel/powermenu.ini"
)

show_main_menu() {
    echo -e "Waybar\nTheme\nWallpaper" | \
        fuzzel "${FUZZEL_COMMON_OPTS[@]}" \
            --placeholder="Customize" \
            --prompt "" \
            --lines=3 \
            --width=25 2>/dev/null
}

show_waybar_menu() {
    echo -e "Toggle layout\nWaybar theme" | \
        fuzzel "${FUZZEL_COMMON_OPTS[@]}" \
            --placeholder="Waybar" \
            --prompt "" \
            --lines=2 \
            --width=25 2>/dev/null
}

show_waybar_theme_menu() {
    local themes=()
    for f in "${WAYBAR_THEMES_DIR}"/*.css; do
        themes+=("$(basename "${f}" .css)")
    done

    printf '%s\n' "${themes[@]}" | \
        fuzzel "${FUZZEL_COMMON_OPTS[@]}" \
            --placeholder="Waybar theme" \
            --prompt "" \
            --lines="${#themes[@]}" \
            --width=25 2>/dev/null
}

random_wallpaper() {
    mapfile -t wallpapers < <(ls -1 "${WALLPAPER_DIR}"/*.jpg "${WALLPAPER_DIR}"/*.png 2>/dev/null)

    if [[ ${#wallpapers[@]} -eq 0 ]]; then
        notify-send "Wallpaper" "No wallpapers found in ${WALLPAPER_DIR}"
        return 1
    fi

    local random_idx=$(( RANDOM % ${#wallpapers[@]} ))
    local random_wallpaper="${wallpapers[$random_idx]}"

    awww img "${random_wallpaper}" 2>/dev/null || \
        hyprctl hyprpaper wallpaper ", ${random_wallpaper}" 2>/dev/null || true

    notify-send "Wallpaper" "Switched to $(basename "${random_wallpaper}")"
}

handle_waybar_menu() {
    local choice="${1}"

    case "${choice}" in
        *layout*)
            "${WAYBAR_TOGGLE}"
            ;;
        *theme*)
            local theme_choice
            theme_choice=$(show_waybar_theme_menu)
            if [[ -n "${theme_choice}" ]]; then
                local current_profile
                current_profile=$("${WAYBAR_TOGGLE}" --current-profile)
                "${WAYBAR_TOGGLE}" "${current_profile}" "${theme_choice}"
                notify-send "Waybar" "Theme set to ${theme_choice}"
            fi
            ;;
    esac
}

main() {
    choice=$(show_main_menu)

    case "${choice}" in
        *Waybar*)
            local waybar_choice
            waybar_choice=$(show_waybar_menu)
            if [[ -n "${waybar_choice}" ]]; then
                handle_waybar_menu "${waybar_choice}"
            fi
            ;;
        *Theme*)
            notify-send "Theme" "Matugen integration coming soon"
            ;;
        *Wallpaper*)
            random_wallpaper
            ;;
    esac
}

main "$@"