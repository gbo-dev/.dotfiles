#!/usr/bin/env bash
set -euo pipefail

config_dir="${HOME}/.config/waybar"
variants_dir="${HOME}/.dotfiles/waybar/.config/waybar/variants"

usage() {
  cat <<'USAGE'
Usage:
  waybar-profile [vertical|horizontal]

With no arguments, toggles between vertical and horizontal profiles.
With an argument, sets the specified profile.

This switches Waybar config/style by updating symlinks:
  config.jsonc -> variants/config-<profile>.jsonc
  style.css    -> variants/style-<profile>.css
USAGE
}

if [[ ${#} -eq 0 ]]; then
  # No args: toggle based on current symlink
  current_link="${config_dir}/config.jsonc"
  if [[ -L "${current_link}" ]]; then
    current_target="$(readlink "${current_link}" || true)"
    if [[ "${current_target}" == *"config-vertical"* ]]; then
      profile="horizontal"
    else
      profile="vertical"
    fi
  else
    # Default to horizontal if no symlink exists
    profile="horizontal"
  fi
  echo "Toggling to: ${profile}"
elif [[ ${#} -eq 1 ]]; then
  profile="${1}"
  case "${profile}" in
    vertical|horizontal) ;;
    -h|--help|help)
      usage
      exit 0
      ;;
    *)
      usage
      exit 2
      ;;
  esac
else
  usage
  exit 2
fi

cfg_src="${variants_dir}/config-${profile}.jsonc"
css_src="${variants_dir}/style-${profile}.css"

if [[ ! -f "${cfg_src}" ]]; then
  echo "Missing: ${cfg_src}" >&2
  exit 1
fi
if [[ ! -f "${css_src}" ]]; then
  echo "Missing: ${css_src}" >&2
  exit 1
fi

ln -sfn "${cfg_src}" "${config_dir}/config.jsonc"
ln -sfn "${css_src}" "${config_dir}/style.css"

pkill waybar && hyprctl dispatch exec waybar

echo "Waybar profile set to: ${profile}"
