#!/usr/bin/env bash
set -euo pipefail

# Resolve canonical dotfiles path (avoid symlinks like ~/.config/waybar)
here_dir="$(cd -- "$(dirname -- "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
waybar_dir="$(cd -- "${here_dir}/.." && pwd)"
variants_dir="${waybar_dir}/variants"

usage() {
  cat <<'USAGE'
Usage:
  waybar-profile [vertical|horizontal]

With no arguments, toggles between vertical and horizontal profiles.
With an argument, sets the specified profile.

This switches Waybar config/style by updating symlinks:
  config.jsonc -> variants/config-<profile>.jsonc
  style.css    -> variants/style-<profile>.css
USAGE
}

if [[ ${#} -eq 0 ]]; then
  # No args: toggle based on current symlink
  current_link="${waybar_dir}/config.jsonc"
  if [[ -L "${current_link}" ]]; then
    current_target="$(readlink "${current_link}" || true)"
    if [[ "${current_target}" == *"config-vertical"* ]]; then
      profile="horizontal"
    else
      profile="vertical"
    fi
  else
    # Default to vertical if no symlink exists
    profile="vertical"
  fi
  echo "Toggling to: ${profile}"
elif [[ ${#} -eq 1 ]]; then
  profile="${1}"
  case "${profile}" in
    vertical|horizontal) ;;
    -h|--help|help)
      usage
      exit 0
      ;;
    *)
      usage
      exit 2
      ;;
  esac
else
  usage
  exit 2
fi

cfg_src="${variants_dir}/config-${profile}.jsonc"
css_src="${variants_dir}/style-${profile}.css"

if [[ ! -f "${cfg_src}" ]]; then
  echo "Missing: ${cfg_src}" >&2
  exit 1
fi
if [[ ! -f "${css_src}" ]]; then
  echo "Missing: ${css_src}" >&2
  exit 1
fi

ln -sfn "${cfg_src}" "${waybar_dir}/config.jsonc"
ln -sfn "${css_src}" "${waybar_dir}/style.css"

echo "Waybar profile set to: ${profile}"

pkill waybar 2>/dev/null || true
sleep 0.1
waybar &
disown
echo "Waybar restarted"
